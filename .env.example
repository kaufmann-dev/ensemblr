# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Encrypts user provider API keys at rest. Use a high-entropy secret.
API_KEY_ENCRYPTION_SECRET=""

# Idempotent seed accounts
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Admin"
DEMO_EMAIL=""
DEMO_PASSWORD=""
DEMO_NAME="Demo"

# Optional comma-separated provider/model ids from models.dev, e.g. openai/gpt-4o-mini,anthropic/claude-3-5-haiku-latest
DEMO_ALLOWED_MODELS=""
