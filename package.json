{
	"name": "ensemblr",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22.13.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "vite-node scripts/seed.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@iconify/tailwind4": "^1.2.3",
		"@inlang/paraglide-js": "^2.15.2",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/mdast": "^4.0.4",
		"@types/node": "^22",
		"better-auth": "~1.4.21",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vite-node": "^6.0.0",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.78",
		"@ai-sdk/cerebras": "^2.0.51",
		"@ai-sdk/cohere": "^3.0.36",
		"@ai-sdk/deepinfra": "^2.0.51",
		"@ai-sdk/google": "^3.0.75",
		"@ai-sdk/groq": "^3.0.39",
		"@ai-sdk/mistral": "^3.0.37",
		"@ai-sdk/openai": "^3.0.64",
		"@ai-sdk/openai-compatible": "^2.0.47",
		"@ai-sdk/perplexity": "^3.0.33",
		"@ai-sdk/togetherai": "^2.0.51",
		"@ai-sdk/xai": "^3.0.91",
		"@fontsource-variable/recursive": "^5.2.8",
		"@openrouter/ai-sdk-provider": "^2.9.0",
		"ai": "^6.0.184",
		"mode-watcher": "^1.1.0",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"unified": "^11.0.5",
		"zod": "^4.4.3"
	}
}
